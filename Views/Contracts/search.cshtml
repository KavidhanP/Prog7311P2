@model IEnumerable<Contract>
@{
    ViewData["Title"] = "Search Contracts";
}

<h1>Search Contracts</h1>
<hr />

<form asp-action="Search" method="get" class="mb-4">
    <div class="row">
        <div class="col-md-3">
            <label class="form-label">Start Date From</label>
            <input type="date" name="startDate" class="form-control"
                   value="@Context.Request.Query["startDate"]" />
        </div>
        <div class="col-md-3">
            <label class="form-label">End Date To</label>
            <input type="date" name="endDate" class="form-control"
                   value="@Context.Request.Query["endDate"]" />
        </div>
        <div class="col-md-3">
            <label class="form-label">Status</label>
            <select name="status" class="form-control">
                <option value="">-- All Statuses --</option>
                <option value="Draft">Draft</option>
                <option value="Active">Active</option>
                <option value="On Hold">On Hold</option>
                <option value="Expired">Expired</option>
            </select>
        </div>
        <div class="col-md-3 d-flex align-items-end">
            <button type="submit" class="btn btn-primary w-100">Search</button>
        </div>
    </div>
</form>

@if (Model != null && Model.Any())
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Contract ID</th>
                <th>Client</th>
                <th>Start Date</th>
                <th>End Date</th>
                <th>Status</th>
                <th>Service Level</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var contract in Model)
            {
                <tr>
                    <td>@contract.ContractId</td>
                    <td>@contract.Client?.Name</td>
                    <td>@contract.StartDate?.ToString("yyyy-MM-dd")</td>
                    <td>@contract.EndDate?.ToString("yyyy-MM-dd")</td>
                    <td>
                        <span class="badge 
                            @(contract.Status == "Active" ? "bg-success" : 
                              contract.Status == "Expired" ? "bg-danger" : 
                              contract.Status == "On Hold" ? "bg-warning" : "bg-secondary")">
                            @contract.Status
                        </span>
                    </td>
                    <td>@contract.ServiceLevel</td>
                    <td>
                        <a asp-action="Details" asp-route-id="@contract.ContractId"
                           class="btn btn-sm btn-info">Details</a>
                        <a asp-action="Edit" asp-route-id="@contract.ContractId"
                           class="btn btn-sm btn-warning">Edit</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
    <p class="text-muted">@Model.Count() contract(s) found.</p>
}
else if (Model != null)
{
    <div class="alert alert-info">No contracts found matching your search criteria.</div>
}

<a asp-action="Index" class="btn btn-secondary">Back to List</a>