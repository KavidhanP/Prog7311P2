@model ServiceRequest
@{
    ViewData["Title"] = "Create Service Request";
}

<h1>Create Service Request</h1>
<h4>ServiceRequest</h4>
<hr />

<div class="row">
    <div class="col-md-6">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group mb-3">
                <label asp-for="ContractId" class="control-label"></label>
                <select asp-for="ContractId" class="form-control" asp-items="ViewBag.ContractId">
                    <option value="">-- Select Contract --</option>
                </select>
                <span asp-validation-for="ContractId" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Description" class="control-label"></label>
                <input asp-for="Description" class="form-control" />
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label>Amount (USD)</label>
                <input type="number" id="costUSD" name="CostUSD" class="form-control"
                       placeholder="Enter amount in USD" step="0.01" min="0" />
                <small class="text-muted">Type a USD amount to auto-convert to ZAR</small>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Cost" class="control-label">Cost (ZAR)</label>
                <input asp-for="Cost" id="costZAR" class="form-control" readonly type ="number" step= "= 0.01"
                       placeholder="Auto-calculated from USD" />
                <span asp-validation-for="Cost" class="text-danger"></span>
                <small id="rateInfo" class="text-muted"></small>
            </div>


            <div class="form-group mt-3">
                <input type="submit" value="Create" class="btn btn-primary" />
                <a asp-action="Index" class="btn btn-secondary ms-2">Back to List</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        let exchangeRate = 0;

        // Fetch rate as soon as page loads
        async function fetchRate() {
            try {
                const response = await fetch('/ServiceRequests/GetExchangeRate');
                const data = await response.json();
                exchangeRate = data.rate;
                document.getElementById('rateInfo').textContent =
                    `Current rate: 1 USD = ${exchangeRate.toFixed(2)} ZAR`;
            } catch {
                document.getElementById('rateInfo').textContent =
                    'Could not load exchange rate.';
            }
        }

        // Auto-calculate ZAR when user types USD
        document.getElementById('costUSD').addEventListener('input', function () {
            const usdAmount = parseFloat(this.value);
            if (!isNaN(usdAmount) && exchangeRate > 0) {
                const zarAmount = parseFloat((usdAmount * exchangeRate).toFixed(2));
                document.getElementById('costZAR').value = zarAmount;
            } else {
                document.getElementById('costZAR').value = '';
            }
        });

        fetchRate();
    </script>
}